# ============================================================
# BL-RWA Fund – Environment Variables Template
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# ============================================================

# ── Existing (strategy) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Blockchain (Polygon Amoy) ────────────────────────────────

# Alchemy RPC URL for Polygon Amoy
# Get yours at: https://dashboard.alchemy.com → Create App → Polygon Amoy
ALCHEMY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Private key of the deployer wallet (prefixed with 0x)
# Fund this address with Amoy MATIC from the faucet:
#   https://faucet.polygon.technology/
DEPLOYER_PRIVATE_KEY=0x...

# Private key of the oracle wallet (can be the same as deployer for testing)
# This wallet must hold the ORACLE_ROLE on the deployed contract
ORACLE_PRIVATE_KEY=0x...

# ── Deployed contracts (filled after running scripts/deploy.js) ──
FUND_CONTRACT_ADDRESS=0x...
USDC_CONTRACT_ADDRESS=0x...

# Address that was granted ORACLE_ROLE during deployment
ORACLE_ADDRESS=0x...

# ── Optional: contract verification ─────────────────────────
# Get your API key at: https://amoy.polygonscan.com/myapikey
POLYGONSCAN_API_KEY=

# ── Alpaca Paper Trading ─────────────────────────────────────
# Get keys at: https://app.alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=PK...
ALPACA_SECRET_KEY=...

# ── Frontend (Vite env vars) ─────────────────────────────────
# These are read by the React frontend (prefix VITE_ required)
VITE_FUND_ADDRESS=0x...
VITE_USDC_ADDRESS=0x...

# ── Strategy settings (unchanged) ───────────────────────────
DEBUG=false
CACHE_DIR=./data
RESULTS_DIR=./results
